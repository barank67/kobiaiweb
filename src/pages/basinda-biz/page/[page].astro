---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { allPressPosts, fallbackPressImage, pressPerPage } from "../../../data/press";

export function getStaticPaths() {
  const totalPages = Math.ceil(allPressPosts.length / pressPerPage);
  return Array.from({ length: Math.max(0, totalPages - 1) }, (_, index) => {
    const page = index + 2;
    return { params: { page: String(page) }, props: { page } };
  });
}

const { page } = Astro.props;
const totalPages = Math.ceil(allPressPosts.length / pressPerPage);
const pagePosts = allPressPosts.slice((page - 1) * pressPerPage, page * pressPerPage);
---
<BaseLayout
  title={`Basında Biz Sayfa ${page} | Kobi AI`}
  description="Kobi AI hakkında basında çıkan haberler, duyurular ve yayınlar."
>
  <section class="page-hero light-page-hero">
    <div class="reveal-box">
      <p>Basında Biz</p>
      <h1>Kobi AI haberleri ve yayınları</h1>
    </div>
  </section>
  <section class="section blog-listing">
    <div class="blog-grid">
      {pagePosts.map((post) => (
        <a class="blog-card lift-card" href={`/basinda-biz/${post.slug}/`}>
          <figure>
            <img src={post.image || fallbackPressImage} alt={post.title} loading="eager" />
          </figure>
          <div>
            <h2>{post.title}</h2>
            <p>{post.excerpt}</p>
          </div>
        </a>
      ))}
    </div>
    <nav class="pagination" aria-label="Basında Biz sayfaları">
      <a href="/basinda-biz/">1</a>
      {Array.from({ length: totalPages - 1 }, (_, index) => {
        const pageNumber = index + 2;
        return pageNumber === page
          ? <span class="is-current">{pageNumber}</span>
          : <a href={`/basinda-biz/page/${pageNumber}/`}>{pageNumber}</a>;
      })}
    </nav>
  </section>
</BaseLayout>
