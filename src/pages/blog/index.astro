---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { posts } from "../../data/site";
---
<BaseLayout title="Blog | Kobi AI">
  <section class="page-hero">
    <div class="reveal-box">
      <p>Blog</p>
      <h1>Yapay zeka ajanları ve KOBİ dönüşümü</h1>
    </div>
  </section>
  <section class="section blog-listing">
    <div class="blog-grid">
      {posts.map((post) => (
        <a class="blog-card lift-card" href={post.href}>
          <figure>
            <img src={post.image} alt={post.title} loading="eager" />
          </figure>
          <div>
            <h2>{post.title}</h2>
            <p>{post.excerpt}</p>
          </div>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
