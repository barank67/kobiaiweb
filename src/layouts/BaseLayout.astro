---
import { navItems, socials, solutionPages } from "../data/site";
import "../styles/global.css";

const {
  title = "Kobi AI",
  description = "Şirketler için agentic AI, yapay zeka ajanları ve iş süreci otomasyonu çözümleri.",
  image = "/assets/images/agentic-ai-bg.webp",
  type = "website",
  publishedTime,
  canonical
} = Astro.props;

const canonicalUrl = canonical ?? new URL(Astro.url.pathname, Astro.site ?? Astro.url.origin).toString();
const imageUrl = new URL(image, Astro.site ?? Astro.url.origin).toString();
const isStaging = new URL(Astro.site ?? Astro.url.origin).hostname === "test.perda.com.tr";
---
<!doctype html>
<html lang="tr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    {isStaging && <meta name="robots" content="noindex, nofollow, noarchive, nosnippet" />}
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:type" content={type} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={imageUrl} />
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    <title>{title}</title>
    <link rel="icon" href="/favicon.png" />
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="/" aria-label="Kobi AI ana sayfa">
        <img class="brand-logo" src="/assets/images/kobiai-logo-main.png" alt="Kobi AI" />
      </a>
      <nav class="main-nav" aria-label="Ana menü">
        {navItems.map((item) => (
          item.children ? (
            <div class="nav-item">
              <a href={item.href} aria-haspopup="true">{item.label}</a>
              <div class="nav-menu">
                {item.children.map((child) => <a href={child.href}>{child.label}</a>)}
              </div>
            </div>
          ) : (
            <a href={item.href}>{item.label}</a>
          )
        ))}
      </nav>
      <a class="header-cta" href="/#iletisim-formu" data-contact-open>Bize Ulaşın</a>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer" id="iletisim">
      <div class="footer-main">
      <div class="footer-column footer-about">
        <a class="brand footer-brand" href="/">
          <img class="brand-logo" src="/assets/images/kobiai-logo-white.png" alt="Kobi AI" />
        </a>
        <p>Otonom AI ekipleri ve akıllı iş akışları.</p>
        <div class="social-links">
          {socials.map((item) => (
            <a href={item.href} target="_blank" rel="noreferrer" aria-label={item.label}>
              <img src={item.icon} alt="" />
              <span>{item.label}</span>
            </a>
          ))}
        </div>
      </div>
      <nav class="footer-column footer-solutions" aria-label="Footer çözümler menüsü">
        <h2>Çözümlerimiz</h2>
        {solutionPages.map((item) => <a href={item.href}>{item.title}</a>)}
      </nav>
      <div class="footer-column">
        <h2>İletişim</h2>
        <p>Kobi Ai Yapay Zeka Çözümleri Ltd.Şti.</p>
        <p>Acıbadem Mah. Derin Sk. Akasya Kule A3 No:8A 34660 Üsküdar / İstanbul</p>
        <a href="mailto:info@kobiai.com.tr">info@kobiai.com.tr</a>
        <a href="tel:+905333346246">+90 533 334 62 46</a>
      </div>
      </div>
      <p class="footer-copy">Kobi AI 2026 © Tüm Hakları Saklıdır.</p>
    </footer>
    <button class="chatbot-toggle" type="button" aria-label="Chatbot'u aç" aria-expanded="false">
      <img src="/assets/images/kobi-ai-chatbot-icon.png" alt="" />
    </button>
    <section class="contact-modal" id="iletisim-formu" aria-hidden="true">
      <div class="contact-modal-backdrop" data-contact-close></div>
      <div class="contact-dialog" role="dialog" aria-modal="true" aria-labelledby="contact-dialog-title">
        <button class="contact-close" type="button" aria-label="İletişim formunu kapat" data-contact-close>×</button>
        <div class="contact-copy">
          <p class="eyebrow">Bize Ulaşın</p>
          <h2 id="contact-dialog-title">İşiniz İçin Doğru Çözümü Birlikte Keşfedelim</h2>
          <p>
            İhtiyacınızı paylaşın; yapay zeka çözümlerimizin işletmenizde nasıl değer üretebileceğini birlikte değerlendirelim.
          </p>
        </div>
        <form id="demo-form" class="contact-form">
          <label>
            <span>Ad Soyad *</span>
            <input type="text" name="name" autocomplete="name" required />
          </label>
          <label>
            <span>Firma</span>
            <input type="text" name="company" autocomplete="organization" />
          </label>
          <label>
            <span>Telefon *</span>
            <input type="tel" name="phone" autocomplete="tel" required />
          </label>
          <label>
            <span>Email *</span>
            <input type="email" name="email" autocomplete="email" required />
          </label>
          <label class="contact-form-wide">
            <span>Mesajınız</span>
            <textarea name="message" rows="5" maxlength="240"></textarea>
          </label>
          <button class="button primary" type="submit">Gönder</button>
          <p class="form-status" aria-live="polite"></p>
        </form>
      </div>
    </section>
    <section class="chatbot-panel" aria-live="polite" aria-hidden="true">
      <div class="chatbot-head">
        <strong>Kobi AI Asistan</strong>
        <button type="button" aria-label="Chatbot'u kapat">×</button>
      </div>
      <div class="chatbot-body">
        <div class="chatbot-messages">
          <p class="bot-message">Merhaba, yapay zeka ajanları hakkında nasıl yardımcı olabilirim?</p>
        </div>
        <div class="chatbot-actions" aria-label="Örnek sorular">
          <button type="button" data-chat-prompt="Yapay Zeka kullanmaya nereden başlamalıyım?">Yapay Zeka kullanmaya nereden başlamalıyım?</button>
          <button type="button" data-chat-prompt="Yapay Zeka işime nasıl katkı yapar?">Yapay Zeka işime nasıl katkı yapar?</button>
          <button type="button" data-chat-prompt="Fazla stok yükünden nasıl kurtulurum?">Fazla stok yükünden nasıl kurtulurum?</button>
        </div>
        <form class="chatbot-form">
          <input type="text" name="chat-message" autocomplete="off" placeholder="Mesajınızı yazın" aria-label="Chatbot mesajı" />
          <button type="submit">Gönder</button>
        </form>
      </div>
    </section>
    <script is:inline>
      document.addEventListener("DOMContentLoaded", () => {
        const toggle = document.querySelector(".chatbot-toggle");
        const panel = document.querySelector(".chatbot-panel");
        const close = document.querySelector(".chatbot-head button");
        const messages = document.querySelector(".chatbot-messages");
        const quickQuestions = document.querySelector(".chatbot-actions");
        const chatForm = document.querySelector(".chatbot-form");
        const chatInput = document.querySelector(".chatbot-form input");
        const demoForm = document.querySelector("#demo-form");
        const formStatus = document.querySelector(".form-status");
        const contactModal = document.querySelector(".contact-modal");
        const contactOpeners = document.querySelectorAll("[data-contact-open]");
        const contactClosers = document.querySelectorAll("[data-contact-close]");
        const chatbotEndpoint = "https://chatbot-858666494590.europe-west1.run.app/chat";
        const getSessionId = () => {
          const key = "kobiai_chat_session_id";
          const existing = window.localStorage.getItem(key);
          if (existing) return existing;
          const id = crypto.randomUUID ? crypto.randomUUID() : `kobiai-${Date.now()}-${Math.random().toString(16).slice(2)}`;
          window.localStorage.setItem(key, id);
          return id;
        };
        const sessionId = getSessionId();
        const setOpen = (open) => {
          panel?.classList.toggle("is-open", open);
          panel?.setAttribute("aria-hidden", open ? "false" : "true");
          toggle?.setAttribute("aria-expanded", open ? "true" : "false");
          if (open) window.setTimeout(() => chatInput?.focus(), 120);
        };
        const addMessage = (text, type = "bot") => {
          if (type === "user") quickQuestions?.classList.add("is-hidden");
          const item = document.createElement("p");
          item.className = type === "user" ? "user-message" : "bot-message";
          item.textContent = text;
          messages?.appendChild(item);
          messages?.scrollTo({ top: messages.scrollHeight, behavior: "smooth" });
          return item;
        };
        const setContactOpen = (open) => {
          contactModal?.classList.toggle("is-open", open);
          contactModal?.setAttribute("aria-hidden", open ? "false" : "true");
          document.body.classList.toggle("has-modal", open);
          if (open) window.setTimeout(() => demoForm?.querySelector("input")?.focus(), 120);
        };
        const buildMailLinks = (subject, body) => ({
          gmailUrl: `https://mail.google.com/mail/?view=cm&fs=1&to=info@kobiai.com.tr&su=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`,
          yahooUrl: `https://compose.mail.yahoo.com/?to=info@kobiai.com.tr&subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`,
          mailtoUrl: `mailto:info@kobiai.com.tr?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`
        });
        const parseBotReply = async (response) => {
          const contentType = response.headers.get("content-type") || "";
          if (contentType.includes("application/json")) {
            const data = await response.json();
            return data.reply || data.answer || data.message || data.response || "Yanıt alındı.";
          }
          return response.text();
        };
        const replyTo = async (text) => {
          const loading = addMessage("Yanıt hazırlanıyor...");
          try {
            const response = await fetch(chatbotEndpoint, {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({ message: text, session_id: sessionId })
            });
            const reply = await parseBotReply(response);
            loading.textContent = response.ok ? reply : `Chatbot yanıt veremedi: ${reply}`;
          } catch (error) {
            loading.textContent = "Chatbot servisine şu anda ulaşılamıyor. Lütfen biraz sonra tekrar deneyin.";
          }
        };
        toggle?.addEventListener("click", () => {
          setOpen(!panel?.classList.contains("is-open"));
        });
        close?.addEventListener("click", () => setOpen(false));
        contactOpeners.forEach((opener) => {
          opener.addEventListener("click", (event) => {
            event.preventDefault();
            setContactOpen(true);
          });
        });
        contactClosers.forEach((closer) => {
          closer.addEventListener("click", () => setContactOpen(false));
        });
        document.querySelectorAll("[data-chat-prompt]").forEach((button) => {
          button.addEventListener("click", () => {
            const text = button.getAttribute("data-chat-prompt") || "";
            addMessage(text, "user");
            replyTo(text);
          });
        });
        chatForm?.addEventListener("submit", (event) => {
          event.preventDefault();
          const text = chatInput?.value.trim();
          if (!text) return;
          addMessage(text, "user");
          chatInput.value = "";
          replyTo(text);
        });
        demoForm?.addEventListener("submit", (event) => {
          event.preventDefault();
          if (!demoForm.reportValidity()) return;
          const data = new FormData(demoForm);
          const body = [
            `Ad Soyad: ${data.get("name")}`,
            `Firma: ${data.get("company") || "-"}`,
            `Telefon: ${data.get("phone")}`,
            `Email: ${data.get("email")}`,
            "",
            `Mesaj: ${data.get("message") || "-"}`
          ].join("\n");
          const subject = "Kobi AI Demo Talebi";
          const { gmailUrl, yahooUrl, mailtoUrl } = buildMailLinks(subject, body);
          const opened = window.open(gmailUrl, "_blank");
          if (opened) opened.opener = null;
          if (!opened) window.location.href = mailtoUrl;
          formStatus.innerHTML = `
            <span>Mesajınız hazırlandı. Gmail yeni sekmede açıldı; açılmadıysa aşağıdaki alternatifleri kullanabilirsiniz.</span>
            <a href="${yahooUrl}" target="_blank" rel="noreferrer">Yahoo</a>
            <a href="${mailtoUrl}">Mail uygulaması</a>
          `;
        });
        document.addEventListener("keydown", (event) => {
          if (event.key === "Escape") setContactOpen(false);
          if (event.key === "Escape") setOpen(false);
        });
      });
    </script>
  </body>
</html>
